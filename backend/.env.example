# ClinicalMind Backend — Environment Variables
# 1. Copy this file:  cp .env.example .env
# 2. Fill in OPENAI_API_KEY and PINECONE_API_KEY
# 3. Everything else works automatically with Docker

# ── App ──────────────────────────────────
DEBUG=true

# ── Database (Docker handles this) ───────
DATABASE_URL=postgresql://postgres:password@db:5432/clinicalmind

# ── Redis (Docker handles this) ──────────
REDIS_URL=redis://redis:6379/0

# ── JWT Secret ───────────────────────────
# Any long random string works here
SECRET_KEY=change-this-to-any-long-random-string-abcdef123456

# ── OpenAI ───────────────────────────────
# Get from: https://platform.openai.com/api-keys
# Used for: GPT-4o Vision diagnosis + Whisper voice transcription
OPENAI_API_KEY=sk-proj-put-your-key-here

# ── Pinecone ─────────────────────────────
# Get from: https://app.pinecone.io → API Keys
# Create index: dimension=1024, metric=cosine, name=clinicalmind-medical
PINECONE_API_KEY=pcsk_put-your-key-here
PINECONE_INDEX_NAME=clinicalmind-medical

# ── File Storage ─────────────────────────
# Local storage is used by default — no cloud needed
# Files are saved to backend/uploads/ folder automatically

# ── MLflow (Docker handles this) ─────────
MLFLOW_TRACKING_URI=http://mlflow:5000

# ── CORS ─────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
